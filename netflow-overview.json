{
  "apiVersion": "dashboard.grafana.app/v1beta1",
  "kind": "Dashboard",
  "metadata": { "name": "netflow-overview" },
  "spec": {
    "title": "[Filebeat Netflow] Overview",
    "description": "High-level summary of all netflow traffic",
    "tags": ["netflow", "filebeat", "network"],
    "editable": true,
    "cursorSync": "Off",
    "preload": false,
    "liveNow": false,
    "timeSettings": {
      "from": "now-6h", "to": "now",
      "autoRefresh": "30s",
      "autoRefreshIntervals": ["5s","10s","30s","1m","5m","15m","30m","1h","2h","1d"],
      "timezone": "browser", "fiscalYearStartMonth": 0, "hideTimepicker": false
    },
    "variables": [],
    "annotations": [],
    "links": [],
    "elements": {
      "panel-1": { "kind": "Panel", "spec": { "title": "Total Flows", "vizConfig": { "kind": "stat", "spec": { "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "value_and_name", "reduceOptions": { "calcs": ["count"], "fields": "", "values": false } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#00d4ff", "mode": "fixed" }, "unit": "short" }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "count" }], "bucketAggs": [], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-2": { "kind": "Panel", "spec": { "title": "Bytes In", "vizConfig": { "kind": "stat", "spec": { "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "value_and_name", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#00ff9d", "mode": "fixed" }, "unit": "bytes" }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "network.direction:ingress", "metrics": [{ "id": "1", "type": "sum", "field": "network.bytes" }], "bucketAggs": [], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-3": { "kind": "Panel", "spec": { "title": "Bytes Out", "vizConfig": { "kind": "stat", "spec": { "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "value_and_name", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#ff7c3d", "mode": "fixed" }, "unit": "bytes" }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "network.direction:egress", "metrics": [{ "id": "1", "type": "sum", "field": "network.bytes" }], "bucketAggs": [], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-4": { "kind": "Panel", "spec": { "title": "Unique Source IPs", "vizConfig": { "kind": "stat", "spec": { "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "textMode": "value_and_name", "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#7c5cfc", "mode": "fixed" }, "unit": "short" }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "cardinality", "field": "source.ip" }], "bucketAggs": [], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-5": { "kind": "Panel", "spec": { "title": "Network Traffic Over Time", "vizConfig": { "kind": "timeseries", "spec": { "options": { "tooltip": { "mode": "all", "sort": "none" }, "legend": { "displayMode": "list", "placement": "bottom" } }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "opacity", "lineInterpolation": "smooth", "showPoints": "auto" } }, "overrides": [ { "matcher": { "id": "byName", "options": "ingress" }, "properties": [{ "id": "color", "value": { "fixedColor": "#00d4ff", "mode": "fixed" } }] }, { "matcher": { "id": "byName", "options": "egress" }, "properties": [{ "id": "color", "value": { "fixedColor": "#7c5cfc", "mode": "fixed" } }] } ] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "sum", "field": "network.bytes" }], "bucketAggs": [ { "id": "2", "type": "terms", "field": "network.direction", "settings": { "size": "10", "order": "desc", "orderBy": "1" } }, { "id": "3", "type": "date_histogram", "field": "@timestamp", "settings": { "interval": "auto", "min_doc_count": "0" } } ], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-6": { "kind": "Panel", "spec": { "title": "Protocol Distribution", "vizConfig": { "kind": "piechart", "spec": { "options": { "pieType": "pie", "displayLabels": ["name","percent"], "tooltip": { "mode": "all" }, "legend": { "displayMode": "list", "placement": "right" } }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [ { "matcher": { "id": "byName", "options": "tcp" }, "properties": [{ "id": "color", "value": { "fixedColor": "#00d4ff", "mode": "fixed" } }] }, { "matcher": { "id": "byName", "options": "udp" }, "properties": [{ "id": "color", "value": { "fixedColor": "#7c5cfc", "mode": "fixed" } }] }, { "matcher": { "id": "byName", "options": "icmp" }, "properties": [{ "id": "color", "value": { "fixedColor": "#00ff9d", "mode": "fixed" } }] } ] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "count" }], "bucketAggs": [ { "id": "2", "type": "terms", "field": "network.transport", "settings": { "size": "10", "order": "desc", "orderBy": "1" } } ], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-7": { "kind": "Panel", "spec": { "title": "Top Source IPs by Bytes", "vizConfig": { "kind": "barchart", "spec": { "options": { "orientation": "horizontal", "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#00d4ff", "mode": "fixed" }, "unit": "bytes", "custom": { "fillOpacity": 80, "lineWidth": 0 } }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "sum", "field": "network.bytes" }], "bucketAggs": [ { "id": "2", "type": "terms", "field": "source.ip", "settings": { "size": "10", "order": "desc", "orderBy": "1" } } ], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-8": { "kind": "Panel", "spec": { "title": "Top Destination IPs by Bytes", "vizConfig": { "kind": "barchart", "spec": { "options": { "orientation": "horizontal", "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#7c5cfc", "mode": "fixed" }, "unit": "bytes", "custom": { "fillOpacity": 80, "lineWidth": 0 } }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "sum", "field": "network.bytes" }], "bucketAggs": [ { "id": "2", "type": "terms", "field": "destination.ip", "settings": { "size": "10", "order": "desc", "orderBy": "1" } } ], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-9": { "kind": "Panel", "spec": { "title": "Top Destination Ports", "vizConfig": { "kind": "barchart", "spec": { "options": { "orientation": "horizontal", "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } }, "fieldConfig": { "defaults": { "color": { "fixedColor": "#00ff9d", "mode": "fixed" }, "unit": "short", "custom": { "fillOpacity": 80, "lineWidth": 0 } }, "overrides": [] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "count" }], "bucketAggs": [ { "id": "2", "type": "terms", "field": "destination.port", "settings": { "size": "10", "order": "desc", "orderBy": "1" } } ], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } },
      "panel-10": { "kind": "Panel", "spec": { "title": "Recent Flow Events", "vizConfig": { "kind": "table", "spec": { "options": { "showHeader": true, "cellHeight": "sm", "footer": { "show": false } }, "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [ { "matcher": { "id": "byName", "options": "network.bytes" }, "properties": [{ "id": "unit", "value": "bytes" }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "gradient" } }, { "id": "color", "value": { "fixedColor": "#00d4ff", "mode": "fixed" } }] }, { "matcher": { "id": "byName", "options": "event.duration" }, "properties": [{ "id": "unit", "value": "ns" }, { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "color", "value": { "fixedColor": "#ff7c3d", "mode": "fixed" } }] } ] } } }, "data": { "kind": "QueryGroup", "spec": { "queries": [ { "kind": "DataQuery", "spec": { "refId": "A", "datasource": { "type": "elasticsearch" }, "query": "", "metrics": [{ "id": "1", "type": "logs" }], "bucketAggs": [], "index": "netflow-*", "timeField": "@timestamp" } } ] } } } }
    },
    "layout": {
      "kind": "GridLayout",
      "spec": {
        "items": [
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-1"  }, "x": 0,  "y": 0,  "width": 6,  "height": 4 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-2"  }, "x": 6,  "y": 0,  "width": 6,  "height": 4 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-3"  }, "x": 12, "y": 0,  "width": 6,  "height": 4 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-4"  }, "x": 18, "y": 0,  "width": 6,  "height": 4 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-5"  }, "x": 0,  "y": 4,  "width": 16, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-6"  }, "x": 16, "y": 4,  "width": 8,  "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-7"  }, "x": 0,  "y": 12, "width": 12, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-8"  }, "x": 12, "y": 12, "width": 12, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-9"  }, "x": 0,  "y": 20, "width": 12, "height": 8 } },
          { "kind": "GridLayoutItem", "spec": { "element": { "kind": "ElementReference", "name": "panel-10" }, "x": 12, "y": 20, "width": 12, "height": 8 } }
        ]
      }
    }
  }
}
